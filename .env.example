APP_NAME=GoldenStackers Inventory
APP_ENV=local
APP_DEFAULT_TIMEZONE=America/Denver
APP_BUILD_VERSION=dev-local
APP_BUILD_SHA=unknown
APP_USER_NAME=employee
APP_USER_ROLE=admin
APP_ALLOW_ROLE_OVERRIDE=true
APP_REQUIRE_PASSWORD_AUTH=false
APP_AUTH_SIGNING_KEY=replace-me-with-long-random-secret
APP_AUTH_REMEMBER_DAYS=14
APP_AUTH_COOKIE_ENABLED=false
APP_AUTH_QUERY_TOKEN_FALLBACK_ENABLED=true
UX_WORKSPACE_EBAY_ENABLED=false

# local Playwright e2e auth seed defaults (used by app/db/seed.py and tests)
E2E_USERNAME=e2e
E2E_PASSWORD=e2e-password-123
E2E_ROLE=admin
E2E_DISPLAY_NAME=E2E Local User
E2E_EMAIL=e2e@goldenstackers.local
E2E_ENSURE_ROLE_PERMISSIONS=true

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=goldenstackers
POSTGRES_USER=goldenstackers
POSTGRES_PASSWORD=goldenstackers

# storage provider config
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=goldenstackers-media
# set for local S3-compatible endpoint (minio/localstack), e.g. http://localhost:9000
S3_ENDPOINT_URL=
# optional CDN/public base url override
S3_PUBLIC_BASE_URL=

# ebay sandbox or production
EBAY_ENVIRONMENT=sandbox

# eBay app credentials
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# eBay redirect values
# EBAY_RU_NAME is the Redirect URL name from eBay developer portal
# EBAY_REDIRECT_URI can be used later when implementing callback endpoint
EBAY_RU_NAME=
EBAY_REDIRECT_URI=
EBAY_AUTH_ACCEPTED_URL=
EBAY_AUTH_DECLINED_URL=
# optional: default user OAuth token used by eBay/Admin verification forms
EBAY_USER_ACCESS_TOKEN=
EBAY_USER_REFRESH_TOKEN=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CURRENCY=USD
EBAY_CONTENT_LANGUAGE=en-US
EBAY_MERCHANT_LOCATION_KEY=
EBAY_PAYMENT_POLICY_ID=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_FINDING_RATE_LIMIT_COOLDOWN_SECONDS=600
EBAY_FINDING_RATE_LIMIT_PROBE_INTERVAL_SECONDS=120

DB_AUTO_MIGRATE=false

COMP_LLM_ENABLED=false
COMP_LLM_PROVIDER=openai
COMP_LLM_BASE_URL=https://api.openai.com/v1
COMP_LLM_ENDPOINT_TYPE=responses
OPENAI_API_KEY=
COMP_LLM_MODEL=gpt-4o-mini
COMP_LLM_TEMPERATURE=0.2
COMP_LLM_MAX_OUTPUT_TOKENS=16000
COMP_LLM_TIMEOUT_SECONDS=60

# Slack Socket Mode inbound ops bot (optional; runtime settings are source of truth in-app)
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=

# background sync runner
SYNC_RUNNER_ENABLED=false
SYNC_RUNNER_INTERVAL_SECONDS=900
SYNC_RUNNER_ACTOR=sync-worker
SYNC_RUNNER_RUN_ONCE=false

# sync job toggles/defaults
SYNC_JOB_EBAY_ORDERS_PULL_IMPORT_ENABLED=true
SYNC_JOB_EBAY_ORDERS_PULL_IMPORT_LIMIT=50
SYNC_JOB_EBAY_ORDERS_PULL_IMPORT_OFFSET=0
SYNC_JOB_EBAY_SHIPPING_TRACKING_PUSH_ENABLED=false
SYNC_JOB_EBAY_CONNECTION_HEALTH_CHECK_ENABLED=true
SYNC_JOB_EBAY_CONNECTION_HEALTH_CHECK_INTERVAL_MINUTES=30
SYNC_JOB_QUICKBOOKS_EXPORT_ENABLED=false
SYNC_JOB_SHOPIFY_ORDERS_PULL_ENABLED=false
SYNC_JOB_SHOPIFY_ORDERS_PULL_SHOP_DOMAIN=
SYNC_JOB_SHOPIFY_ORDERS_PULL_ACCESS_TOKEN=
SYNC_JOB_SHOPIFY_ORDERS_PULL_LIMIT=50
SYNC_JOB_SHOPIFY_ORDERS_PULL_OFFSET=0
